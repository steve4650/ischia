[
  {
    "tags": "andromeda",
    "block": [
      {
        "name": "Create /etc/wireguard directory",
        "ansible.builtin.file": {
          "path": "/etc/wireguard",
          "state": "directory",
          "mode": "0700",
          "owner": "root",
          "group": "root"
        },
        "become": "yes"
      },
      {
        "name": "Install WireGuard interface configuration",
        "ansible.builtin.copy": {
          "src": "andromeda.conf",
          "dest": "/etc/wireguard/andromeda.conf",
          "owner": "root",
          "group": "root",
          "mode": "0600"
        },
        "become": "yes"
      },
      {
        "name": "Install Andromeda private key",
        "ansible.builtin.copy": {
          "src": "ischia.priv",
          "dest": "/etc/wireguard/ischia.priv",
          "owner": "root",
          "group": "root",
          "mode": "0600"
        },
        "become": "yes"
      },
      {
        "name": "Install Andromeda public key",
        "ansible.builtin.copy": {
          "src": "ischia.pub",
          "dest": "/etc/wireguard/ischia.pub",
          "owner": "root",
          "group": "root",
          "mode": "0600"
        },
        "become": "yes"
      },
      {
        "name": "Create andromeda OpenRC service",
        "ansible.builtin.copy": {
          "dest": "/etc/init.d/andromeda",
          "content": "#!/sbin/openrc-run\ndescription=\"Andromeda WireGuard VPN\"\n\ndepend() {\n    need net\n    use dns\n}\n\nstart() {\n    ebegin \"Starting andromeda\"\n    /usr/bin/wg-quick up /etc/wireguard/andromeda.conf\n    eend $?\n}\n\nstop() {\n    ebegin \"Stopping andromeda\"\n    /usr/bin/wg-quick down /etc/wireguard/andromeda.conf\n    eend $?\n}\n",
          "mode": "0755",
          "owner": "root",
          "group": "root"
        },
        "register": "andromeda_service",
        "become": "yes"
      },
      {
        "name": "Enable and start andromeda service",
        "ansible.builtin.service": {
          "name": "andromeda",
          "enabled": true,
          "state": "started"
        },
        "when": "andromeda_service.changed",
        "become": "yes"
      }
    ]
  }
]
