[
  {
    "tags": "caddy",
    "block": [
      {
        "name": "Render Caddyfile from template",
        "ansible.builtin.copy": {
          "src": "Caddyfile",
          "dest": "/etc/caddy/Caddyfile",
          "owner": "root",
          "group": "root"
        },
        "register": "caddyfile",
        "become": "yes"
      },
      {
        "name": "Enable caddy service",
        "ansible.builtin.service": {
          "name": "caddy",
          "state": "restarted",
          "enabled": true
        },
        "when": "caddyfile.changed",
        "become": "yes"
      }
    ]
  }
]
