[
  {
    "tags": "ntp",
    "block": [
      {
        "name": "Copy ntp.conf into place",
        "ansible.builtin.copy": {
          "src": "ntp.conf",
          "dest": "/etc/ntp.conf",
          "owner": "root",
          "group": "root",
          "mode": "0644"
        },
        "register": "ntpconf",
        "become": "yes"
      },
      {
        "name": "Enable ntpd service",
        "ansible.builtin.service": {
          "name": "ntpd",
          "state": "restarted",
          "enabled": true
        },
        "when": "ntpconf.changed",
        "become": "yes"
      }
    ]
  }
]
